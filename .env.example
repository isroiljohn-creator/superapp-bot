# ── Environment ────────────────────────────────────
ENVIRONMENT=development

# ── Telegram Bot ───────────────────────────────────
BOT_TOKEN=your_bot_token_here
WEBAPP_URL=https://your-app.railway.app
RAILWAY_PUBLIC_DOMAIN=your-app.railway.app
WEBHOOK_URL=
WEBHOOK_PATH=/webhook/tg
WEBHOOK_SECRET=your-secret-token

# ── Gemini AI ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINIGEN_API_KEY=your_geminigen_api_key
AISHA_API_KEY=your_aisha_api_key

# ── YMove / VideoDB ────────────────────────────────
YMOVE_API_KEY=ym_your_api_key
VIDEO_DB_CHANNEL_ID=-100xxxxxxxxxx

# ── Database ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── Redis ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Payments — Telegram ────────────────────────────
PAYMENT_PROVIDER_TOKEN=your_payment_provider_token

# ── Payments — Click ───────────────────────────────
CLICK_MERCHANT_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=

# ── Payments — Payme ───────────────────────────────
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# ── Feature flags ──────────────────────────────────
PAYMENTS_ENABLED=false
ANALYTICS_ENABLED=true

# ── AmoCRM ─────────────────────────────────────────
AMOCRM_DOMAIN=your-company.amocrm.ru
AMOCRM_ACCESS_TOKEN=your_amocrm_token
AMOCRM_SALES_GROUP_ID=

# ── Admin / Bot Settings ───────────────────────────
ADMIN_IDS_STR=123456789,987654321
ADMIN_API_KEY=
ADMIN_DEV_BYPASS=
PRIVATE_GROUP_ID=0
CONTENT_CHANNEL_ID=0
CLUB_PRICE=97000
